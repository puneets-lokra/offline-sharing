        <mxCell id="flow-steps" parent="flow-summary" style="text;html=1;fontSize=10;align=left;verticalAlign=top;" value="① Both devices connect to ClinicBridge Wi-Fi hotspot&#xa;② Doctor opens http://192.168.137.1:8765 — PWA loads (cached)&#xa;③ Doctor fills patient record → saved to IndexedDB (pending)&#xa;④ bridgeSync detects bridge → POST /data to bridge&#xa;⑤ Bridge upserts record into SQLite → { ok: true }&#xa;⑥ Client 2 polls GET /records every 5s → table updates&#xa;⑦ (Later) Bridge detects internet → pushes to Cloud API" vertex="1">
          <mxGeometry height="120" width="510" x="15" y="30" as="geometry" />
