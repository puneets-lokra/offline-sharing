        <mxCell id="flow-summary" parent="1" style="swimlane;startSize=25;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#27ae60;fontStyle=1;fontSize=11;" value="Offline Sync Flow (No Internet Required)" vertex="1">
          <mxGeometry height="160" width="540" x="1040" y="1009" as="geometry" />
