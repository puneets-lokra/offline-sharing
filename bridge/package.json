{
  "name": "offline-bridge",
  "version": "1.0.0",
  "description": "Offline clinic data bridge — Wi-Fi Direct hotspot + SQLite + cloud sync",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "package": "npm run build && pkg . --config pkg.config.json --out-path dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "bonjour-service": "^1.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "qrcode": "^1.5.4",
    "sql.js": "^1.12.0",
    "uuid": "^9.0.0"
  },
  "optionalDependencies": {
    "@abandonware/bleno": "^0.6.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/qrcode": "^1.5.6",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^9.0.7",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
