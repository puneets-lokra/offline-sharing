{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "docs/PRD.md"],
  "autoupdate": true,
  "snapshot": true,
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "write": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "build/**", "*.exe"]
  }
}
